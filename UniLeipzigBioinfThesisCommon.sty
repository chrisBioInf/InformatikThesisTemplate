%Package for List of Symbols
\RequirePackage[intoc]{nomencl}
\renewcommand{\nomname}{List of Symbols}
\renewcommand{\nomprefix}{}
\makenomenclature

% Functions for symbols
\newcommand{\makesymbols}{
    \cleardoublepage
    \markboth{\nomname}{\nomname}
    \printnomenclature
}
\RequirePackage{xspace}
\NewDocumentCommand{\sym}{moomo}{%
    \IfValueTF{#5}{%
        \nomenclature[#5]{$#1$}{#4}%
    }%
    {%
        \nomenclature{$#1$}{#4}%
    }%
    \IfValueTF{#2}{%
        \IfValueTF{#3}{%
            \expandafter\def\csname sym#2\endcsname{\ensuremath{#3}\xspace}%
        }%
        {%
            \expandafter\def\csname sym#2\endcsname{\ensuremath{#1}\xspace}%
        }%
    }%

}
\NewDocumentCommand{\operatorsym}{moomo}{%
    \IfValueTF{#4}{%
        \nomenclature[#4]{$\operatorname{#1}$}{#4}%
    }%
    {%
        \nomenclature{$\operatorname{#1}$}{#4}%
    }%
    \IfValueTF{#2}{%
        \IfValueTF{#3}{%
            \expandafter\def\csname sym#2\endcsname{%
                \ensuremath{\operatorname{#3}}\xspace}%
        }%
        {%
            \expandafter\def\csname sym#2\endcsname{%
                \ensuremath{\operatorname{#1}}\xspace}%
        }%
    }%

}

\NewDocumentCommand{\macrosym}{mmomooooo}{%
    \IfValueTF{#6}{%
        \IfValueTF{#7}{%
            \IfValueTF{#8}{%
                \IfValueTF{#9}{%
                    \expandafter\def\csname sym#2\endcsname##1##2##3##4##5{#1}%
                    \expandafter\def\csname symT#2\endcsname##1##2##3##4##5{$#1$}%
                    \IfValueTF{#3}{%
                        \expandafter\nomenclature[#3]{$\csname sym#2\endcsname{#5}{#6}{#7}{#8}{#9}$}{#4}%
                    }%
                    {%
                        \expandafter\nomenclature{$\csname sym#2\endcsname{#5}{#6}{#7}{#8}{#9}$}{#4}%
                    }%
                }%
                {%
                    \expandafter\def\csname sym#2\endcsname##1##2##3##4{#1}%
                    \expandafter\def\csname symT#2\endcsname##1##2##3##4{$#1$}%
                    \IfValueTF{#3}{%
                        \expandafter\nomenclature[#3]{$\csname sym#2\endcsname{#5}{#6}{#7}{#8}$}{#4}%
                    }%
                    {%
                        \expandafter\nomenclature{$\csname sym#2\endcsname{#5}{#6}{#7}{#8}$}{#4}%
                    }%
                }%
            }%
            {%
                \expandafter\def\csname sym#2\endcsname##1##2##3{#1}%
                \expandafter\def\csname symT#2\endcsname##1##2##3{$#1$}%
                \IfValueTF{#3}{%
                    \expandafter\nomenclature[#3]{$\csname sym#2\endcsname{#5}{#6}{#7}$}{#4}%
                }%
                {%
                    \expandafter\nomenclature{$\csname sym#2\endcsname{#5}{#6}{#7}$}{#4}%
                }%
            }%
        }%
        {%
            \expandafter\def\csname sym#2\endcsname##1##2{#1}%
            \expandafter\def\csname symT#2\endcsname##1##2{$#1$}%
            \IfValueTF{#3}{%
                \expandafter\nomenclature[#3]{$\csname sym#2\endcsname{#5}{#6}$}{#4}%
            }%
            {%
                \expandafter\nomenclature{$\csname sym#2\endcsname{#5}{#6}$}{#4}%
            }%
        }%
    }%
    {%
        \expandafter\def\csname sym#2\endcsname##1{#1}%
        \expandafter\def\csname symT#2\endcsname##1{$#1$}%
        \IfValueTF{#3}{%
            \expandafter\nomenclature[#3]{$\csname sym#2\endcsname{#5}$}{#4}%
        }%
        {%
            \expandafter\nomenclature{$\csname sym#2\endcsname{#5}$}{#4}%
        }%
    }%
}


\newcommand{\allSymCats}[1]{}

\NewDocumentCommand{\addSymbolCategory}{mm}{
    \expandafter\let\csname oldsymcatcommand#1\endcsname=\allSymCats%
    \renewcommand{\allSymCats}[1]{
        \csname oldsymcatcommand#1\endcsname{##1}
        \ifthenelse{\equal{##1}{#1}}{\item[\textbf{#2}]}{}
    }
}

\def\initSymbolCategory{%
    \renewcommand{\nomgroup}[1]{%
        \allSymCats{##1}%
    }
}

\AtEndPreamble{\initSymbolCategory}


%Package for List of Abbreviations
\ifBioinfThesisCmn@noglossary%
    \NewDocumentCommand{\defabb}{omomo}{}}
    \newcommand{\abb}[1]{#1}
    \newcommand{\abbs}[1]{#1s}
    \newcommand{\indexdef}[1]{\marginnote{\textbf{#1}}}
    \newcommand{\indexbf}[1]{\textbf{#1}}

\else
    \RequirePackage[acronym,nomain,toc,nonumberlist,savewrites]{glossaries}
    \glsdisablehyper
    \ifBioinfThesisCmn@definitionindex%
        \newglossary*{margin}{Definition Index}
    \fi

    \makeglossaries
    %Def index commands
    \newcommand{\indexnomn}[1]{%
        \ifBioinfThesisCmn@definitionindex%
            \newglossaryentry{index:#1}{type=margin,name={#1},description=\nopostdesc,nonumberlist=false}%
            \glsadd{index:#1}%
        \fi%
    }
    \newcommand{\indexdef}[1]{%
        \leavevmode\marginnote{\textbf{#1}}\ignorespaces%
        \indexnomn{#1}%
    }
    \newcommand{\indexbf}[1]{%
        \textbf{#1}%
        \indexnomn{#1}%
    }


    %Abbrevitaion commands
    \newcommand{\helpabb}[1]{%
        \ifnum \BioinfThesis@maxdis=0%
        \else%
            \@ifundefined{c@#1abb}{%
                %\NewDocumentCounter[initial=-100]{#1abb}%
                \newcounter{#1abb}%
                \setcounter{#1abb}{-100}%
            }{}%
            \ifnum \numexpr\value{page}-\value{#1abb}\relax%
            >%
            \BioinfThesis@maxdis \glsreset{#1}\fi%
            \setcounter{#1abb}{\value{page}}%
        \fi%
    }
    %
    \NewDocumentCommand{\defabb}{omomo}{%
        \IfValueTF{#1}%
        {%  % If given a label for the abbreviation, use it.
            \def\abblabel{#1}
        }%
        {%  % Otherwise, simple use the short acronym as label.
            \def\abblabel{#2}
        }%
        \IfValueTF{#3}%
        {%
            \IfValueTF{#5}%
            {%
                \newacronym[shortplural={#3},longplural={#5}]{\abblabel}{#2}{#4}
            }%
            {%
                \newacronym[shortplural={#3}]{\abblabel}{#2}{#4}
            }%
        }%
        {%
            \IfValueTF{#5}%
            {%
                \newacronym[longplural={#5}]{\abblabel}{#2}{#4}
            }%
            {%
                \newacronym{\abblabel}{#2}{#4}
            }%
        }
    }
    \newcommand{\abb}[1]{\helpabb{#1}\gls{#1}}
    \newcommand{\abbs}[1]{\helpabb{#1}\glspl{#1}}
\fi



