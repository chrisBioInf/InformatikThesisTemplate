% Set up todo notes. Supports options margin, plain, and off.
\newcommand{\BioinfThesisCmn@todosetup}[1]{%
    \ifdefstring{#1}{margin}{
        \RequirePackage{todonotes}
        \let\marginpar\marginnote       % fixes todo notes in floats (figures/tabs)
    }{
        % Make empty pgfsyspdfmark command to prevent compile error when todonotes
        % has been loaded before but option value is changed to another value.
        \newcommand{\pgfsyspdfmark}[3]{}
        \ifdefstring{#1}{plain}{
            \newcommand{\todo}[1]{\begingroup\tiny\color{red}[##1]\endgroup}
        }{
            \ifdefstring{#1}{off}{
                \newcommand{\todo}[1]{}
            }{
                \PackageError{UniLeipzigBioinfThesisCommon.sty}{%
                    Unknown value `#1' for option `todo'}{%
                    Supported values are `margin', `plain', and `off'.}
            }
        }
    }
}

