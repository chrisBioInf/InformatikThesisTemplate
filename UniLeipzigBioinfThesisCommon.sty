% Print the bibliography, optionally with a given title.
\newcommand{\printthebibliography}[1][Bibliography]{%
    \ifBioinfThesisCmn@bibtex%      % print using BibTeX
        %\addto\captionsenglish{\renewcommand{\bibname}{#1}}     % set title
        \renewcommand{\bibname}{#1}     % set title
        \addcontentsline{toc}{section}{Bibliography}
        \bibliography{\bibfile}
    \else                           % print using BibLaTeX
        \printbibliography[heading=bibintoc,title={#1}]
    \fi
}

