% Make declaration at the end of the thesis.
\newcommand{\makedeclaration}{
    \cleardoublepage
    \begin{otherlanguage}{ngerman}
        % The 2cm hspace are currently required due to the compensation of
        % -2cm required for the rest of the odd thesis header, cf.
        %  \makeoddhead in UniLeipzigBioinfThesis.cls.
        \markboth{Selbstständigkeitserklärung}{\hspace{2cm}Selbstständigkeitserklärung}
        \chapter*{Selbstständigkeitserklärung}
        \vspace*{0.07\textheight}
        {%
            \noindent\large
            Hiermit erkläre ich, die vorliegende Dissertation selbstständig
            und ohne unzulässige fremde Hilfe angefertigt zu haben. Ich habe
            keine anderen als die angeführten Quellen und Hilfsmittel benutzt
            und sämtliche Textstellen, die wörtlich oder sinngemäß aus
            veröffentlichten oder unveröffentlichten Schriften entnommen
            wurden, und alle Angaben, die auf mündlichen Auskünften beruhen,
            als solche kenntlich gemacht. Ebenfalls sind alle von anderen
            Personen bereitgestellten Materialien oder erbrachten
            Dienstleistungen als solche gekennzeichnet.
        }
        \vfill

        \noindent
        \rule[0.5em]{25em}{0.5pt}

        \noindent Ort, Datum
        \vspace{15mm}

        \noindent
        \rule[0.5em]{25em}{0.5pt}

        \noindent
        Unterschrift
    \end{otherlanguage}
}

% Set biblatex name style, i.e. order of first/given names.
\newcommand{\setbiblatexnamestyle}[1]{
    \ifdefstring{#1}{fg}{%
        \DeclareNameAlias{author}{family-given}
    }{%
        \ifdefstring{#1}{gf}{%
            \DeclareNameAlias{author}{given-family}
        }{%
            \ifdefstring{#1}{fggf}{%
                \DeclareNameAlias{author}{%
                    family-given/given-family}
            }{%
                \PackageError{UniLeipzigBioinfThesisCommon.sty}{%
                    Unknown value `#1' in command setbiblatexnamestyle}{}
            }
        }
    }
}

% Configure biblatex to (1) prevent DOIs/URLs from running into the margin and
% (2) to interpret underline annotations in the bib files.
\newcounter{itisfrontmatter}    % make sure counter exists
\newcounter{sharedfirstauthor}
\newcommand{\configurebiblatex}{
    % Prevent URLs/DOIs in bibliography from running into margin:
    \setcounter{biburlnumpenalty}{9000}
    \setcounter{biburllcpenalty}{9000}
    \setcounter{biburlucpenalty}{9000}

    \newcommand{\hight}[1]{%
        \ifnum\value{itisfrontmatter}=1%
            \ifitemannotation{underlinebase}{%
                \underline{##1}%
            }{%
                \ifitemannotation{underlineall}{%
                    \underline{##1}%
                }{%
                    ##1%
                }%
            }%
            \ifitemannotation{firstauthor}{%
                \footnotemark[1]\setcounter{sharedfirstauthor}{1}%
            }{}%
        \else%
            \ifitemannotation{underlineall}{%
                \underline{##1}%
            }{%
                ##1%
            }%
        \fi%
    }

    \renewbibmacro*{name:family-given}[4]{%
      \ifuseprefix{%
        \usebibmacro{name:delim}{##3##1}%
        \usebibmacro{name:hook}{##3##1}%
        \ifdefvoid{##3}{}{%
          \ifcapital{%
            \mkbibnameprefix{\MakeCapital{##3}}\isdot%
          }{%
            \mkbibnameprefix{##3}\isdot%
          }%
          \ifprefchar{}{\bibnamedelimc}%
        }%
         \hight{%
           \mkbibnamefamily{##1}\isdot%
           \ifdefvoid{##4}{}{\bibnamedelimd\mkbibnamesuffix{##4}\isdot}%
           \ifdefvoid{##2}{}{\revsdnamepunct\bibnamedelimd\mkbibnamegiven{##2}\isdot}%
         }%
      }{%
        \usebibmacro{name:delim}{##1}%
        \usebibmacro{name:hook}{##1}%
        \hight{%
          \mkbibnamefamily{##1}\isdot%
          \ifdefvoid{##4}{}{\bibnamedelimd\mkbibnamesuffix{##4}\isdot}%
          \ifboolexpe{%
            test {\ifdefvoid{##2}}
            and
            test {\ifdefvoid{##3}}%
          }{}{%
            \revsdnamepunct%
          }%
          \ifdefvoid{##2}{}{\bibnamedelimd\mkbibnamegiven{##2}\isdot}%
          \ifdefvoid{##3}{}{\bibnamedelimd\mkbibnameprefix{##3}\isdot}%
        }%
      }%
    }

    \renewbibmacro*{name:given-family}[4]{%
      \usebibmacro{name:delim}{##2##3##1}%
      \usebibmacro{name:hook}{##2##3##1}%
      \hight{\ifdefvoid{##2}{}{\mkbibnamegiven{##2}\isdot\bibnamedelimd}%
      \ifdefvoid{##3}{}{%
        \mkbibnameprefix{##3}\isdot%
        \ifprefchar{%
        }{%
          \ifuseprefix{\bibnamedelimc}{\bibnamedelimd}%
        }%
      }%
      \mkbibnamefamily{##1}\isdot%
      \ifdefvoid{##4}{}{\bibnamedelimd\mkbibnamesuffix{##4}\isdot}}
    }%

    % Set biblatex name style, i.e. order of first/given names.
    \setbiblatexnamestyle{\BioinfThesisCmn@bibauthorstyle}
}

